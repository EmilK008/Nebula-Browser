{
  "manifest_version": 3,
  "name": "Nebula Step 4 Test",
  "version": "1.0.0",
  "description": "Tests extension toolbar icon, popup, and options page in Nebula.",
  "action": {
    "default_title": "Nebula Step 4",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "32": "icons/icon32.svg"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
